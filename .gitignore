# ─────────────────────────────────────────────────────────────
#  Notas — .gitignore
# ─────────────────────────────────────────────────────────────

# ===== Python (backend) =====
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python
pip-wheel-metadata/

# Tests / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Variables de entorno (¡NO ignorar los .env.example!)
.env
.env.*
!.env.example

# Bases de datos locales
*.db
*.sqlite
*.sqlite3

# ===== Node (frontend / frontend-alt) =====
node_modules/
dist/
dist-ssr/
build/
.vite/
.svelte-kit/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Caches de herramientas
.cache/
.parcel-cache/
.turbo/
.eslintcache

# ===== Editores / IDE =====
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo

# ===== Sistema operativo =====
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
